[Unit]
Description=ROV task launcher daemon (pi_launcher.py)
After=network-online.target
Wants=network-online.target

[Service]
User=pi
ExecStart=/usr/bin/python3 -u /home/pi/Control-Systems-Code/pi_launcher.py --dir /home/pi/Control-Systems-Code --port 5010
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
